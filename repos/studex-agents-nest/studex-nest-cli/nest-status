#!/bin/bash
# nest-status — Full VM health check: PM2, Docker, Disk, RAM

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check ~/nest exists
if [ ! -d "$HOME/nest" ]; then
    echo -e "${RED}Error: ~/nest not found${NC}"
    exit 1
fi

echo -e "${BLUE}=== PM2 Processes ===${NC}"
if command -v pm2 &> /dev/null; then
    pm2 list 2>/dev/null || echo "PM2 not running"
else
    echo "PM2 not installed"
fi

echo ""
echo -e "${BLUE}=== Docker Containers ===${NC}"
if command -v docker &> /dev/null; then
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || echo "Docker not running"
else
    echo "Docker not installed"
fi

echo ""
echo -e "${BLUE}=== Disk Space ===${NC}"
df -h / /home 2>/dev/null | head -5

echo ""
echo -e "${BLUE}=== Memory (RAM) ===${NC}"
free -h

echo ""
# Health assessment
HEALTH="OK"
DISK_USAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
RAM_USAGE=$(free | grep Mem | awk '{printf "%.0f", $3/$2 * 100}')

if [ "$DISK_USAGE" -gt 90 ] || [ "$RAM_USAGE" -gt 90 ]; then
    HEALTH="CRITICAL"
elif [ "$DISK_USAGE" -gt 75 ] || [ "$RAM_USAGE" -gt 75 ]; then
    HEALTH="WARNING"
fi

if [ "$HEALTH" = "OK" ]; then
    echo -e "${GREEN}VM Health: OK${NC}"
elif [ "$HEALTH" = "WARNING" ]; then
    echo -e "${YELLOW}VM Health: WARNING${NC}"
else
    echo -e "${RED}VM Health: CRITICAL${NC}"
fi
