#!/bin/bash
# nest-discord — Check Discord bot status

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${BLUE}Discord bot: checking...${NC}"

# Check if Discord container is running
if command -v docker &> /dev/null; then
    if docker ps --format "{{.Names}}" | grep -q "discord"; then
        echo -e "${GREEN}Discord bot: RUNNING${NC}"
        docker ps --filter "name=discord" --format "table {{.Names}}\t{{.Status}}"
    else
        echo -e "${RED}Discord bot: Not running${NC}"
        echo "Run: docker ps -a | grep discord"
    fi
else
    # Check via PM2
    if command -v pm2 &> /dev/null; then
        if pm2 jlist 2>/dev/null | grep -q "discord"; then
            echo -e "${GREEN}Discord bot: RUNNING (PM2)${NC}"
        else
            echo -e "${RED}Discord bot: Not running${NC}"
        fi
    else
        echo -e "${YELLOW}Discord bot: Unknown (no Docker/PM2)${NC}"
    fi
fi

echo ""
echo "Port 3001 check:"
if command -v curl &> /dev/null; then
    if curl -s --max-time 3 http://localhost:3001 > /dev/null 2>&1; then
        echo -e "${GREEN}Port 3001: Responding${NC}"
    else
        echo -e "${YELLOW}Port 3001: No response${NC}"
    fi
fi
