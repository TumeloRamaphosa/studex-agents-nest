#!/bin/bash
# nest-today — Today's date, SA time, ADAM work summary

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${BLUE}=== StudEx Nest CLI — $(date '+%A, %d %B %Y') ===${NC}"
echo ""

# SA time (UTC+2)
SA_TIME=$(TZ="Africa/Johannesburg" date '+%H:%M %Z')
echo -e "${GREEN}SA Time: $SA_TIME${NC}"

# UTC time
echo "UTC:     $(date -u '+%H:%M')"

echo ""
echo -e "${BLUE}=== ADAM SMASHER AI — Today's Work ===${NC}"
echo ""

# Check Git log for recent commits
if [ -d "$HOME/nest" ]; then
    echo -e "${YELLOW}Recent commits:${NC}"
    cd ~/nest && git log --oneline -5 2>/dev/null || echo "No commits found"
    echo ""
fi

# Daily status
echo "Status: Operations Active"
echo "Discord Bot: Monitoring"
echo "Market Data: Running"
echo "Pipeline: 4 Active Deals"

echo ""
echo -e "${GREEN}System operational${NC}"
