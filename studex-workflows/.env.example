# Studex Workflow Engine — Environment Variables
# Copy to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── AgentMail (WhatsApp) ─────────────────────────────────────
AGENTMAIL_API_KEY=am_us_24fcb06c6b1babba88c56d49b1a83fc33f1b8acf153acf3ef905136f335e7502
AGENTMAIL_BASE_URL=https://api.agentmail.to/v0

# ─── WhatsApp Notifications ─────────────────────────────────────
# Primary ops number (Naledi / Tumelo)
WHATSAPP_NOTIFY_NUMBER=+27XXXXXXXXX

# ─── Discord Webhook ─────────────────────────────────────────────
# Create a webhook in your Discord server: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/HERE

# ─── Shopify ─────────────────────────────────────────────────────
# Your Shopify store URL (e.g. https://studexmeat.myshopify.com)
SHOPIFY_STORE_URL=https://YOUR-STORE.myshopify.com
# Admin API access token (from Shopify Partners or admin API)
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
